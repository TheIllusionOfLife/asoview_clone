# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
project_id    = "asoview-clone-dev"
region        = "asia-northeast1"
zone          = "asia-northeast1-a"
support_email = "you@example.com"

# Let's Encrypt account registration email. You receive expiry warnings at
# this address. REQUIRED. After `terraform apply`, also sed-replace
# EDIT_ME@example.com in infra/k8s/edge/clusterissuer.yaml with the same
# value so the ClusterIssuer manifest matches.
letsencrypt_email = "you@example.com"

# DuckDNS subdomain (the part before .duckdns.org). Claim one at
# https://www.duckdns.org. The full host becomes <this>.duckdns.org.
# Default matches the hostname committed in infra/k8s/edge/ingress.yaml.
duckdns_subdomain = "asoview-clone-dev"

# Optional: provide a domain you own (e.g. "asoview-clone.dev") to skip
# DuckDNS. When set AND duckdns_subdomain is empty, terraform creates a
# Cloud DNS zone + A record pointing at the static IP. Unused in the
# default DuckDNS flow.
domain = ""
