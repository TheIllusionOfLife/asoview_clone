# Asoview! web — public env vars (NEXT_PUBLIC_*) only.
# Copy to .env.local and fill in for local development.

# Gateway base URL (Spring Cloud Gateway proxying /v1/**)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Firebase web config (from Identity Platform / Firebase console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to use the Firebase Auth Emulator (local + CI). Leave blank for real OAuth.
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_URL=http://localhost:9099

# Stripe test-mode publishable key (pk_test_*).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Set to "1" to enable the Playwright fake-checkout harness (?fakeMode=1).
# MUST be unset / "0" in production builds — the app throws if set in prod.
NEXT_PUBLIC_FAKE_CHECKOUT_MODE=0
