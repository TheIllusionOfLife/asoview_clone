{
  "name": "@asoview/asoview-web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "cd ../.. && biome check apps/asoview-web/src",
